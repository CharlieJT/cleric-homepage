---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Cleric - The AI SRE That Learns From Your Engineers',
  description = 'Cleric investigates production issues, captures what works, and makes your whole team faster.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preload critical fonts -->
    <link 
      rel="preload" 
      href="/src/fonts/ClericSans/Cleric Sans woff2/Cleric-Sans-Text-400.woff2" 
      as="font" 
      type="font/woff2" 
      crossorigin 
    />
    <link 
      rel="preload" 
      href="/src/fonts/GT Alpina/GT-Alpina-Standard-Regular.woff2" 
      as="font" 
      type="font/woff2" 
      crossorigin 
    />
    
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900 font-cleric-sans">
    <slot />
  </body>
</html>
