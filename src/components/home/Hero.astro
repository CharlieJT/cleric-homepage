---
// Hero component with background image, headline, CTAs, and overlapping product images
import heroBackground from '../../assets/hero-background-image.jpg';
import heroActivity from '../../assets/hero-activity-image.png';
import heroThread from '../../assets/hero-thread-image.png';
import heroMobile from '../../assets/hero-mobile-image.png';
---

<section class="relative max-h-[150vh] xs:max-h-screen pt-24 overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img 
      src={heroBackground.src} 
      alt="" 
      class="w-full h-full object-cover object-top"
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-10 sm:px-14 lg:pt-16 lg:pb-20 pt-20 md:pt-20">
    <!-- Press Release Badge -->
    <div class="flex justify-center mb-12">
      <a 
        href="#" 
        class="inline-flex items-center gap-3 bg-black/10 backdrop-blur-sm rounded-md px-4 py-2 text-sm hover:bg-black/40 transition-colors"
      >
        <span class="bg-white/80 text-black-300 text-md px-3 py-1 rounded-sm">
          Press release
        </span>
        <span class="text-white/80 font-medium">
          Cleric launches the first self-learning AI SRE
        </span>
        <svg class="w-4 h-4 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
        </svg>
      </a>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl md:text-7xl lg:text-7xl font-gt-alpina text-white text-center max-w-4xl mx-auto leading-tight mb-6">
      The AI SRE That Learns<br class="hidden sm:block" /> From Your Engineers
    </h1>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl lg:text-[1.4rem] text-white/90 text-center max-w-2xl mx-auto mb-8">
      Cleric investigates production issues, captures what works, and makes your whole team faster.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 lg:mb-30">
      <a 
        href="#" 
        class="w-full sm:w-auto bg-white text-navy px-8 py-3 rounded-full font-semibold text-center text-base hover:bg-gray-100 transition-colors shadow-lg"
      >
        Start for Free
      </a>
      <a 
        href="#" 
        class="w-full sm:w-auto border-2 border-white text-white px-8 py-3 rounded-full font-semibold text-center text-base hover:bg-white/10 transition-colors"
      >
        Request Demo
      </a>
    </div>

    <!-- Product Images - Desktop/Tablet -->
    <div class="hidden md:block relative w-full mx-auto mt-16 mb-[-120px]">
      <div class="relative">
        <!-- Activity Image (Main - Nearly full width) -->
        <img 
          src={heroActivity.src} 
          alt="Cleric Activity Dashboard" 
          class="w-full rounded-xl shadow-2xl"
        />
        
        <!-- Thread Image (Bigger, bottom right, overlapping into fade) -->
        <img 
          src={heroThread.src} 
          alt="Cleric Thread View" 
          class="absolute -bottom-6 right-0 lg:right-0 xl:-right-10 w-64 lg:w-80 rounded-xl shadow-2xl"
        />
      </div>
    </div>

    <!-- Product Image - Mobile -->
    <div class="md:hidden relative max-w-full mx-0 mb-[-80px]">
      <img 
        src={heroMobile.src} 
        alt="Cleric Mobile View" 
        class="w-full rounded-xl shadow-2xl"
      />
    </div>
  </div>

  <!-- Bottom Gradient Fade -->
  <div class="absolute bottom-0 left-0 right-0 h-48 md:h-64 bg-gradient-to-t from-white to-transparent z-10 pointer-events-none"></div>
</section>
